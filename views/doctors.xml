<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_hospital_doctor_form" model="ir.ui.view">
        <field name="name">hospital.doctor.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <group>
                        <group string="Basic Information">
                            <field name="name"/>
                            <field name="department"/>
                        </group>
                    </group>

                    <group string="💰 Consultation Fees">
                        <div class="alert alert-info" role="alert">
                            Set fees for each appointment duration.
                            These will be shown to patients when booking.
                        </div>
                        <group>
                            <field name="fee_10min" string="10 Minutes — Quick Check-up (Rs.)"/>
                            <field name="fee_20min" string="20 Minutes — Standard Consultation (Rs.)"/>
                            <field name="fee_40min" string="40 Minutes — Detailed Examination (Rs.)"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- DOCTOR TREE VIEW                          -->
    <!-- ========================================= -->
    <record id="view_hospital_doctor_tree" model="ir.ui.view">
        <field name="name">hospital.doctor.tree</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <tree string="Doctors">
                <field name="name"/>
                <field name="department"/>
                <field name="fee_10min" string="10 Min Fee (Rs.)"/>
                <field name="fee_20min" string="20 Min Fee (Rs.)"/>
                <field name="fee_40min" string="40 Min Fee (Rs.)"/>
            </tree>
        </field>
    </record>


    <record id="action_hospital_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first doctor
            </p>
        </field>
    </record>
</odoo>