<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hospital_patient_tree" model="ir.ui.view">
        <field name="name">hospital.patient.tree</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <tree string="Patients">
                <field name="name"/>
                <field name="date_of_birth" optional="show"/>
                <field name="gender" optional="hide"/>
                <field name="phone" optional="show"/>
                <field name="email" optional="show"/>
            </tree>

        </field>
    </record>

    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form string="Patients">
                <sheet>
                    <group>
                        <group string="Personal Info">
                            <field name="name"/>
                            <field name="date_of_birth"/>
                            <field name="gender"/>
                        </group>
                        <group string="Contact Info">
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                        </group>
                    </group>
                    <group>
                        <field name="tag_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_users"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_ids" eval="[Command.clear(),
                  (0,0,{'view_mode':'tree', 'view_id': ref('view_hospital_patient_tree')}),
                  (0,0,{'view_mode':'form', 'view_id': ref('view_hospital_patient_form')})]"/>
        <field name="view_mode">tree,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_hospital">Create new patient</p>
        </field>
    </record>
</odoo>