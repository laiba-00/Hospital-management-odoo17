<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ══════════════════════════════════════════ -->
    <!-- Portal Home — Appointments Count          -->
    <!-- ══════════════════════════════════════════ -->
    <template id="portal_my_home_appointment"
              inherit_id="portal.portal_my_home"
              name="Portal: Appointments">
        <xpath expr="//div[@id='portal_client_category']" position="after">
            <t t-if="appointment_count" t-call="portal.portal_docs_entry">
                <t t-set="document_name" t-value="'Appointments'"/>
                <t t-set="url" t-value="'/my/appointments'"/>
                <t t-set="count" t-value="appointment_count"/>
                <t t-set="name" t-value="'Appointments'"/>
            </t>
        </xpath>
    </template>

    <!-- ══════════════════════════════════════════ -->
    <!-- Register Page                             -->
    <!-- ══════════════════════════════════════════ -->
    <template id="hospital_register_page" name="Hospital Register">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-5">
                        <div class="card shadow">
                            <div class="card-header bg-dark text-white text-center">
                                <h4>Create Account</h4>
                            </div>
                            <div class="card-body p-4">
                                <t t-if="error">
                                    <div class="alert alert-danger">
                                        <t t-esc="error"/>
                                    </div>
                                </t>
                                <form action="/hospital/register/submit" method="POST">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <div class="mb-3">
                                        <label class="form-label">Full Name</label>
                                        <input type="text" name="name" class="form-control"
                                               placeholder="Ali Khan" required="required"/>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Email</label>
                                        <input type="email" name="email" class="form-control"
                                               placeholder="ali@email.com" required="required"/>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Password</label>
                                        <input type="password" name="password"
                                               class="form-control"
                                               placeholder="••••••••" required="required"/>
                                    </div>
                                    <button type="submit"
                                            class="btn btn-dark w-100">
                                        Create Account
                                    </button>
                                    <div class="text-center mt-3">
                                        <a href="/hospital/login">
                                            Already have account? Login
                                        </a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ══════════════════════════════════════════ -->
    <!-- Login Page                                -->
    <!-- ══════════════════════════════════════════ -->
    <template id="hospital_login_page" name="Hospital Login">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-5">
                        <div class="card shadow">
                            <div class="card-header bg-dark text-white text-center">
                                <h4>Login</h4>
                            </div>
                            <div class="card-body p-4">
                                <t t-if="error">
                                    <div class="alert alert-danger">
                                        <t t-esc="error"/>
                                    </div>
                                </t>
                                <form action="/hospital/login/submit" method="POST">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <div class="mb-3">
                                        <label class="form-label">Email</label>
                                        <input type="email" name="email" class="form-control"
                                               placeholder="ali@email.com" required="required"/>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Password</label>
                                        <input type="password" name="password"
                                               class="form-control"
                                               placeholder="••••••••" required="required"/>
                                    </div>
                                    <button type="submit" class="btn btn-dark w-100">
                                        Login
                                    </button>
                                    <div class="text-center mt-3">
                                        <a href="/hospital/register">
                                            New user? Create Account
                                        </a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ══════════════════════════════════════════ -->
    <!-- Book Appointment Form                     -->
    <!-- ══════════════════════════════════════════ -->
    <template id="hospital_book_appointment" name="Book Appointment">
        <t t-call="website.layout">
            <div class="container mt-4">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card shadow">
                            <div class="card-header bg-dark text-white">
                                <h4>Book Appointment</h4>
                            </div>
                            <div class="card-body p-4">
                                <form action="/hospital/book/submit" method="POST"
                                      id="booking_form">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="slot_start" id="slot_start"/>
                                    <input type="hidden" name="slot_end" id="slot_end"/>
                                    <input type="hidden" name="fee" id="fee_hidden"/>
                                    <input type="hidden" name="duration" id="duration_hidden"/>

                                    <h5 class="fw-bold mb-3">Your Information</h5>
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Full Name</label>
                                            <input type="text" name="patient_name"
                                                   class="form-control"
                                                   placeholder="Ali Khan" required="required"/>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Email</label>
                                            <input type="email" name="patient_email"
                                                   class="form-control"
                                                   placeholder="ali@email.com" required="required"/>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Phone</label>
                                            <input type="text" name="patient_phone"
                                                   class="form-control"
                                                   placeholder="03001234567" required="required"/>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Gender</label>
                                            <select name="patient_gender" class="form-select"
                                                    required="required">
                                                <option value="">-- Select Gender --</option>
                                                <option value="male">Male</option>
                                                <option value="female">Female</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Date of Birth</label>
                                            <input type="date" name="patient_dob"
                                                   class="form-control"/>
                                        </div>
                                    </div>
                                    <hr/>
                                    <h5 class="fw-bold mb-3">Step 1 — Select Doctor</h5>
                                    <div class="mb-3">
                                        <select name="doctor_id" id="doctor_select"
                                                class="form-select" required="required"
                                                onchange="updateFees()">
                                            <option value="">-- Select Doctor --</option>
                                            <t t-foreach="doctors" t-as="doctor">
                                                <option t-att-value="doctor.id"
                                                        t-att-data-fee10="doctor.fee_10min"
                                                        t-att-data-fee20="doctor.fee_20min"
                                                        t-att-data-fee40="doctor.fee_40min">
                                                    <t t-esc="doctor.name"/> —
                                                    <t t-esc="doctor.department"/>
                                                </option>
                                            </t>
                                        </select>
                                    </div>
                                    <h5 class="fw-bold mb-3">Step 2 — Select Date</h5>
                                    <div class="mb-3">
                                        <input type="date" name="date_appointment"
                                               id="date_input" class="form-control"
                                               required="required" onchange="loadSlots()"/>
                                    </div>
                                    <h5 class="fw-bold mb-3">Step 3 — Select Duration</h5>
                                    <div class="mb-3">
                                        <div class="row">
                                            <div class="col-md-4 mb-2">
                                                <div class="card" id="card_10"
                                                     onclick="selectDuration(10)"
                                                     style="cursor:pointer;
                                                            border:2px solid #dee2e6;">
                                                    <div class="card-body text-center p-3">
                                                        <h5>10 Min</h5>
                                                        <p class="text-muted mb-1">
                                                            Quick Check-up
                                                        </p>
                                                        <h6 class="text-success" id="fee_10">
                                                            Rs. 0
                                                        </h6>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4 mb-2">
                                                <div class="card" id="card_20"
                                                     onclick="selectDuration(20)"
                                                     style="cursor:pointer;
                                                            border:2px solid #dee2e6;">
                                                    <div class="card-body text-center p-3">
                                                        <h5>20 Min</h5>
                                                        <p class="text-muted mb-1">Standard</p>
                                                        <h6 class="text-success" id="fee_20">
                                                            Rs. 0
                                                        </h6>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4 mb-2">
                                                <div class="card" id="card_40"
                                                     onclick="selectDuration(40)"
                                                     style="cursor:pointer;
                                                            border:2px solid #dee2e6;">
                                                    <div class="card-body text-center p-3">
                                                        <h5>40 Min</h5>
                                                        <p class="text-muted mb-1">Detailed</p>
                                                        <h6 class="text-success" id="fee_40">
                                                            Rs. 0
                                                        </h6>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div id="slots_section" style="display:none;">
                                        <h5 class="fw-bold mb-3">
                                            Step 4 — Select Time Slot
                                        </h5>
                                        <div id="slots_container" class="row mb-3"></div>
                                    </div>
                                    <div id="fee_display" style="display:none;"
                                         class="alert alert-success text-center mb-3">
                                        <h5>Consultation Fee:
                                            <strong id="fee_show">Rs. 0</strong>
                                        </h5>
                                    </div>
                                    <button type="submit" id="submit_btn"
                                            class="btn btn-dark w-100"
                                            style="display:none;">
                                        Confirm Appointment
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <script type="text/javascript"
                    src="/om_hospital/static/src/js/hospital_booking.js"/>
        </t>
    </template>

    <!-- ══════════════════════════════════════════ -->
    <!-- My Appointments List                      -->
    <!-- ══════════════════════════════════════════ -->
    <template id="portal_appointments_list" name="My Appointments">
        <t t-call="portal.portal_layout">
            <div class="container mt-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold">My Appointments</h3>
                    <a href="/hospital/book" class="btn btn-dark">
                        <i class="fa fa-plus me-1"/>Book New
                    </a>
                </div>
                <t t-if="not appointments">
                    <div class="alert alert-info">
                        <p>No appointments yet.</p>
                        <a href="/hospital/book" class="btn btn-dark mt-2">
                            Book Appointment
                        </a>
                    </div>
                </t>
                <t t-if="appointments">
                    <div class="card">
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead style="background:#1e293b;">
                                        <tr>
                                            <th style="color:#fff; padding:12px 16px;">
                                                Reference
                                            </th>
                                            <th style="color:#fff; padding:12px 16px;">
                                                Doctor
                                            </th>
                                            <th style="color:#fff; padding:12px 16px;">
                                                Date
                                            </th>
                                            <th style="color:#fff; padding:12px 16px;">
                                                Time
                                            </th>
                                            <th style="color:#fff; padding:12px 16px;">
                                                Fee
                                            </th>
                                            <th style="color:#fff; padding:12px 16px;">
                                                Status
                                            </th>
                                            <th style="color:#fff; padding:12px 16px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="appointments" t-as="apt">
                                            <tr>
                                                <td style="padding:12px 16px;">
                                                    <t t-esc="apt.reference"/>
                                                </td>
                                                <td style="padding:12px 16px;">
                                                    <t t-esc="apt.doctor_id.name"/>
                                                </td>
                                                <td style="padding:12px 16px;">
                                                    <t t-esc="apt.date_appointment"/>
                                                </td>
                                                <td style="padding:12px 16px;">
                                                    <t t-esc="apt.slot_time"/>
                                                </td>
                                                <td style="padding:12px 16px;">
                                                    Rs. <t t-esc="apt.consultation_fee"/>
                                                </td>
                                                <td style="padding:12px 16px;">
                                                    <span t-attf-class="badge #{apt.state == 'confirmed' and 'bg-success' or apt.state == 'draft' and 'bg-warning text-dark' or apt.state == 'cancelled' and 'bg-danger' or 'bg-info'}">
                                                        <t t-esc="apt.state"/>
                                                    </span>
                                                </td>
                                                <td style="padding:12px 16px;">
                                                    <a t-attf-href="/my/appointments/#{apt.id}"
                                                       class="btn btn-sm btn-dark">
                                                        View
                                                    </a>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </t>
    </template>

    <!-- ══════════════════════════════════════════ -->
    <!-- Appointment Detail                        -->
    <!-- ══════════════════════════════════════════ -->
    <template id="portal_appointment_detail" name="Appointment Detail">
        <t t-call="portal.portal_layout">
            <div class="container mt-4">
                <div class="card">
                    <div class="card-header bg-dark text-white">
                        <h4>Appointment —
                            <t t-esc="appointment.reference"/>
                        </h4>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h5 class="fw-bold">Patient Information</h5>
                                <table class="table table-bordered">
                                    <tr>
                                        <td><strong>Name</strong></td>
                                        <td>
                                            <t t-esc="appointment.patient_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>DOB</strong></td>
                                        <td><t t-esc="appointment.date_of_birth"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <h5 class="fw-bold">Doctor Information</h5>
                                <table class="table table-bordered">
                                    <tr>
                                        <td><strong>Doctor</strong></td>
                                        <td><t t-esc="appointment.doctor_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Department</strong></td>
                                        <td><t t-esc="appointment.department"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        <hr/>
                        <table class="table table-bordered">
                            <tr>
                                <td><strong>Date</strong></td>
                                <td><t t-esc="appointment.date_appointment"/></td>
                            </tr>
                            <tr>
                                <td><strong>Time Slot</strong></td>
                                <td><t t-esc="appointment.slot_time"/></td>
                            </tr>
                            <tr>
                                <td><strong>Duration</strong></td>
                                <td>
                                    <t t-esc="appointment.appointment_duration"/> mins
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Status</strong></td>
                                <td><t t-esc="appointment.state"/></td>
                            </tr>
                        </table>
                        <div class="text-center p-4"
                             style="background:#f8f9fa; border-radius:12px;
                                    border:2px solid #1e293b;">
                            <h5 class="fw-bold">Consultation Fee</h5>
                            <h3 class="fw-bold">
                                Rs. <t t-esc="appointment.consultation_fee"/>
                            </h3>
                        </div>
                        <div class="mt-4">
                            <a href="/my/appointments" class="btn btn-dark">
                                <i class="fa fa-arrow-left me-1"/>Back
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ══════════════════════════════════════════ -->
    <!-- Doctors List                              -->
    <!-- ══════════════════════════════════════════ -->
    <template id="hospital_doctors_list" name="Doctors List">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">
                <div class="text-center mb-5">
                    <h2 class="fw-bold">Our Doctors</h2>
                </div>
                <div class="row g-4">
                    <t t-foreach="doctors" t-as="doctor">
                        <div class="col-lg-4 col-md-6">
                            <div class="card h-100"
                                 style="border-radius:14px;
                                        box-shadow:0 2px 12px rgba(0,0,0,0.07);">
                                <div class="card-body p-4 text-center">
                                    <div style="width:60px; height:60px; border-radius:50%;
                                                background:#1e293b; display:flex;
                                                align-items:center; justify-content:center;
                                                margin:0 auto 12px;">
                                        <i class="fa fa-user-md fa-2x" style="color:#fff;"/>
                                    </div>
                                    <h5 class="fw-bold">
                                        <t t-esc="doctor.name"/>
                                    </h5>
                                    <p class="text-muted small mb-3">
                                        <t t-esc="doctor.department"/>
                                    </p>
                                    <div style="background:#f8f9fa; border-radius:10px;
                                                padding:12px; text-align:left;">
                                        <div style="display:flex; justify-content:space-between;
                                                    padding:5px 0;
                                                    border-bottom:1px solid #e2e8f0;
                                                    font-size:13px;">
                                            <span class="text-muted">10 Min</span>
                                            <span style="font-weight:600;">
                                                Rs. <t t-esc="doctor.fee_10min"/>
                                            </span>
                                        </div>
                                        <div style="display:flex; justify-content:space-between;
                                                    padding:5px 0;
                                                    border-bottom:1px solid #e2e8f0;
                                                    font-size:13px;">
                                            <span class="text-muted">20 Min</span>
                                            <span style="font-weight:600;">
                                                Rs. <t t-esc="doctor.fee_20min"/>
                                            </span>
                                        </div>
                                        <div style="display:flex; justify-content:space-between;
                                                    padding:5px 0; font-size:13px;">
                                            <span class="text-muted">40 Min</span>
                                            <span style="font-weight:600;">
                                                Rs. <t t-esc="doctor.fee_40min"/>
                                            </span>
                                        </div>
                                    </div>
                                    <a href="/hospital/book"
                                       class="btn btn-dark w-100 mt-3">
                                        Book Appointment
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- ══════════════════════════════════════════ -->
    <!-- Doctor Schedule Page                      -->
    <!-- ══════════════════════════════════════════ -->
    <template id="hospital_doctor_schedule_page" name="Doctor Schedule Page">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">
                <div class="text-center mb-5">
                    <h2 class="fw-bold">
                        <i class="fa fa-calendar me-2"/>
                        Doctor Schedules
                    </h2>
                    <p class="text-muted">
                        Check doctor availability before booking your appointment
                    </p>
                </div>
                <div class="row g-4">
                    <t t-foreach="doctors" t-as="doctor">
                        <div class="col-lg-4 col-md-6">
                            <div class="card h-100"
                                 style="border-radius:14px; border:none;
                                        box-shadow:0 2px 12px rgba(0,0,0,0.07);
                                        overflow:hidden;">

                                <!-- Header — black theme -->
                                <div style="background:#1e293b; padding:20px;
                                            display:flex; align-items:center; gap:14px;">
                                    <div style="width:52px; height:52px; border-radius:50%;
                                                background:rgba(255,255,255,0.15);
                                                display:flex; align-items:center;
                                                justify-content:center; flex-shrink:0;">
                                        <i class="fa fa-user-md fa-lg" style="color:#fff;"/>
                                    </div>
                                    <div>
                                        <h5 style="color:#fff; margin:0; font-weight:700;">
                                            <t t-esc="doctor.name"/>
                                        </h5>
                                        <small style="color:rgba(255,255,255,0.7);">
                                            <i class="fa fa-hospital-o me-1"/>
                                            <t t-esc="doctor.department"/>
                                        </small>
                                    </div>
                                </div>

                                <div class="card-body p-0">

                                    <!-- Fees -->
                                    <div style="padding:16px 18px;
                                                border-bottom:1px solid #f1f5f9;">
                                        <div style="font-size:11px; font-weight:700;
                                                    color:#94a3b8; letter-spacing:0.6px;
                                                    margin-bottom:10px;">
                                            CONSULTATION FEES
                                        </div>
                                        <div style="display:flex; justify-content:space-between;
                                                    padding:5px 0;
                                                    border-bottom:1px solid #f1f5f9;
                                                    font-size:13px;">
                                            <span class="text-muted">10 Min</span>
                                            <span style="font-weight:700;">
                                                Rs. <t t-esc="doctor.fee_10min"/>
                                            </span>
                                        </div>
                                        <div style="display:flex; justify-content:space-between;
                                                    padding:5px 0;
                                                    border-bottom:1px solid #f1f5f9;
                                                    font-size:13px;">
                                            <span class="text-muted">20 Min</span>
                                            <span style="font-weight:700;">
                                                Rs. <t t-esc="doctor.fee_20min"/>
                                            </span>
                                        </div>
                                        <div style="display:flex; justify-content:space-between;
                                                    padding:5px 0; font-size:13px;">
                                            <span class="text-muted">40 Min</span>
                                            <span style="font-weight:700;">
                                                Rs. <t t-esc="doctor.fee_40min"/>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Weekly Schedule -->
                                    <div style="padding:16px 18px;">
                                        <div style="font-size:11px; font-weight:700;
                                                    color:#94a3b8; letter-spacing:0.6px;
                                                    margin-bottom:10px;">
                                            WEEKLY SCHEDULE
                                        </div>
                                        <t t-foreach="['monday','tuesday','wednesday','thursday','friday','saturday','sunday']"
                                           t-as="day">
                                            <t t-foreach="doctor.schedule_ids" t-as="sch">
                                                <t t-if="sch.weekday == day and sch.is_available">
                                                    <div style="display:flex; align-items:center;
                                                                justify-content:space-between;
                                                                padding:7px 0;
                                                                border-bottom:1px solid #f8f9fb;
                                                                font-size:13px;">
                                                        <span style="font-weight:600;
                                                                     min-width:90px;">
                                                            <t t-esc="day.title()"/>
                                                        </span>
                                                        <span style="color:#64748b;
                                                                     font-size:12px;">
                                                            <t t-esc="sch.time_display"/>
                                                        </span>
                                                        <span style="background:#1e293b;
                                                                     color:#fff;
                                                                     padding:2px 8px;
                                                                     border-radius:20px;
                                                                     font-size:11px;
                                                                     font-weight:600;">
                                                            Available
                                                        </span>
                                                    </div>
                                                </t>
                                            </t>
                                        </t>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

